# .env.example — Copy this to .env and fill in your values.
# Never commit .env — it is gitignored.

# Primary model provider (used by gap_detector and generation_loop)
# Add whichever providers you plan to use:
XAI_API_KEY=your_grok_api_key_here
ANTHROPIC_API_KEY=your_claude_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model names (adjust to whatever you decide on)
PRIMARY_MODEL=grok-4-fast
CODEGEN_MODEL=claude-sonnet-4-6

# Archi-Core settings
ARCHI_LOG_LEVEL=INFO
ARCHI_TEST_COMMAND=pytest tests/
